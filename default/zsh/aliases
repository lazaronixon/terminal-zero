# File system
alias ls='eza -lh --group-directories-first --icons=auto'
alias lsa='ls -a'
alias lt='eza --tree --level=2 --long --icons --git'
alias lta='lt -a'
alias ff="fzf --preview 'bat --style=numbers --color=always {}'"
alias cd="zd"

# Directories
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Tools
alias c='opencode'
alias cx='printf "\033[2J\033[3J\033[H" && claude --permission-mode bypassPermissions'
alias d='docker'
alias r='rails'
alias n='nv'
alias ic='tdl c'
alias ix='tdl cx'

# Git
alias g='git'
alias gcm='git commit -m'
alias gcam='git commit -a -m'
alias gcad='git commit -a --amend'

# Functions
zd() {
  if [ $# -eq 0 ]; then
    builtin cd ~ && return
  elif [ -d "$1" ]; then
    builtin cd "$1"
  else
    z "$@" && printf "\U000F17A9 " && pwd
  fi
}

nv() {
  if [ "$#" -eq 0 ]; then nvim .; else nvim "$@"; fi;
}

tdl() {
  osascript - "$1" <<'EOF'
on run argv
  set aiTool to item 1 of argv
  tell application "Ghostty"
    set ed to focused terminal of selected tab of front window
    set tm to split ed direction down
    perform action "resize_split:down,275" on tm
    set ai to split ed direction right
    perform action "resize_split:right,315" on ai
    input text ("nvim ." & return) to ed
    input text (aiTool & return) to ai
    focus ed
  end tell
end run
EOF
}
